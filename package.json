{
  "name": "nuxt-svgo-sprite",
  "version": "2.0.0",
  "description": "Nuxt module to create SVG sprites",
  "keywords": [
    "nuxt",
    "nuxt-module",
    "svg",
    "sprite",
    "svgo"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/infinityavoid/nuxt-svgo-sprite"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/module.mjs",
      "require": "./dist/module.mjs",
      "types": "./dist/module.d.mts"
    }
  },
  "main": "./dist/module.mjs",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "nuxi dev playground",
    "build": "nuxt-module-build build",
    "prepare": "nuxt-module-build build",
    "lint": "eslint --ext .js,.ts,.vue .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@nuxt/kit": "^4.1.2",
    "svgo": "^4.0.0"
  },
  "devDependencies": {
    "@nuxt/module-builder": "^1.0.1",
    "eslint": "^9.30.1",
    "prettier": "^3.6.2"
  },
  "peerDependencies": {
    "vue": "^3.5.21"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}